<Page x:Class="BurgerPlus.PageBurgerPlus.Admin"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BurgerPlus.PageBurgerPlus"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Страница Андминистратора">

    <Grid>
        <TextBlock Text="Страница администратора" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="50" Margin="0,0,0,100"/>

        <Button Click="EditUsers_Click" 
                Content="Редактировать пользователей" 
                Width="200" Height="35" 
                Margin="0,250,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"/>

        <Button Click="Button_Click" 
                Height="30" Width="100" Content="Выход" 
                Margin="0,300,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"/>
    </Grid>
</Page>
